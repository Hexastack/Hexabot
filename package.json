{
  "name": "@hexabot-ai/monorepo",
  "private": true,
  "version": "3.2.0-alpha.0",
  "description": "Hexabot is a solution for creating and managing chatbots across multiple channels, leveraging AI for advanced conversational capabilities. It provides a user-friendly interface for building, training, and deploying chatbots with integrated support for various messaging platforms.",
  "author": "Hexastack",
  "license": "FCL-1.0-ALv2",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "clean": "turbo run clean",
    "prepare": "husky",
    "release:prepatch": "./bump-version.sh prepatch",
    "release:preminor": "./bump-version.sh preminor",
    "release:prerelease": "./bump-version.sh prerelease",
    "dev:api": "turbo run dev --filter=@hexabot-ai/api --filter=@hexabot-ai/agentic --filter=@hexabot-ai/types --parallel"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "concurrently": "^9.2.1",
    "husky": "^9.0.11",
    "rimraf": "^6.0.1",
    "turbo": "^2.2.3"
  },
  "pnpm": {
    "overrides": {
      "cross-spawn": "7.0.6",
      "cross-spawn>path-key": "3.1.1",
      "react-is": "18.3.1",
      "baseline-browser-mapping": "2.10.19"
    }
  },
  "engines": {
    "node": "^20.19.0"
  }
}

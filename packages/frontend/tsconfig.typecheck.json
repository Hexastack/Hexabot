{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "hexabot/src/*": ["src/*"],
      "@hexabot-ai/agentic": ["../agentic/src"],
      "@hexabot-ai/agentic/*": ["../agentic/src/*"],
      "@hexabot-ai/graph": ["../graph/src"],
      "@hexabot-ai/graph/*": ["../graph/src/*"],
      "@hexabot-ai/types": ["../types/src"],
      "@hexabot-ai/types/*": ["../types/src/*"]
    }
  }
}

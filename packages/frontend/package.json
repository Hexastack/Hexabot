{
  "name": "@hexabot-ai/frontend",
  "private": true,
  "version": "3.2.0-alpha.0",
  "description": "Hexabot is a solution for creating and managing chatbots across multiple channels, leveraging AI for advanced conversational capabilities. It provides a user-friendly interface for building, training, and deploying chatbots with integrated support for various messaging platforms.",
  "author": "Hexastack",
  "license": "FCL-1.0-ALv2",
  "scripts": {
    "dev": "vite",
    "dev:static": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 8080",
    "start": "pnpm run preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "pnpm run lint:fix",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit --downlevelIteration -p tsconfig.typecheck.json"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix --config eslint.config-staged.cjs"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@fontsource/roboto": "^5.1.0",
    "@hexabot-ai/agentic": "workspace:*",
    "@hexabot-ai/graph": "workspace:*",
    "@hexabot-ai/types": "workspace:*",
    "@hexabot-ai/widget": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^7.0.0",
    "@mui/lab": "^7.0.0",
    "@mui/material": "^7.0.0",
    "@mui/utils": "^7.0.0",
    "@mui/x-charts": "^7.29.1",
    "@mui/x-data-grid": "^7.29.9",
    "@rjsf/core": "^6.2.5",
    "@rjsf/mui": "^6.2.5",
    "@rjsf/utils": "^6.2.5",
    "@tanstack/react-query": "^5.90.8",
    "@xyflow/react": "^12.10.0",
    "axios": "^1.12.2",
    "dayjs": "^1.11.13",
    "dompurify": "3.2.7",
    "i18next-http-backend": "^2.6.2",
    "jsonschema": "^1.5.0",
    "lucide-react": "^0.562.0",
    "marked": "14.0.0",
    "monaco-editor": "^0.55.1",
    "monaco-yaml": "^5.4.0",
    "normalizr": "^3.6.2",
    "notistack": "^3.0.1",
    "qs": "^6.12.1",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.51.5",
    "react-i18next": "^14.1.1",
    "react-is": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "socket.io-client": "^4.7.5",
    "yaml": "^2.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "^5.90.2",
    "@types/node": "20.12.12",
    "@types/qs": "^6.9.15",
    "@types/react": "18.3.2",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@vitejs/plugin-react": "^4.4.0",
    "eslint": "^9.37.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-header": "^3.1.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "lint-staged": "^15.3.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vite": "^5.0.11",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "^20.19.0"
  }
}
